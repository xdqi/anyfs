root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{c,h,cc,cpp}]
indent_style = tab
indent_size = 8

[*.{ts,tsx,js,jsx,mjs,cjs,json}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab

[*.{md,yml,yaml}]
indent_style = space
indent_size = 2
